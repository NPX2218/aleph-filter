\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces Void duplicates grow exponentially: each expansion doubles every existing copy. However, the table also doubles, so the \emph  {fraction} of void entries remains constant per generation.}}{26}{figure.caption.36}\protected@file@percent }
\newlabel{fig:void-tree}{{3.3}{26}{Void duplicates grow exponentially: each expansion doubles every existing copy. However, the table also doubles, so the \emph {fraction} of void entries remains constant per generation}{figure.caption.36}{}}
