\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces A void entry at slot 3 is duplicated to slots 6 and 7 during expansion. The filter cannot determine which is correct, so it places a copy in both.}}{25}{figure.caption.35}\protected@file@percent }
